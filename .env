# ─── Server ─────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/artspace
# Production example:
# MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/artspace

# ─── JWT ─────────────────────────────────────────
# Generate a strong secret: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=replace_this_with_a_64_char_random_string_in_production
JWT_EXPIRES=7d

# ─── CORS ────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://artspace.co.ke

# ─── Cloudinary (optional — for cloud image storage) ─
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
